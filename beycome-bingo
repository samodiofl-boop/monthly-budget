    font-size: 12px;
    padding: 4px 10px;
    border-radius: 20px;
    min-width: 70px;
    text-align: center;
  }
  .lb-wins.zero { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.3); }

  /* ---- Instructions ---- */
  .instructions {
    max-width: 520px;
    margin: 24px auto 0;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
