<style>
  :root {
    --navy: #0d1b3e;
    --gold: #f5a623;
    --gold-light: #ffd166;
    --green: #06d6a0;
    --red: #ef233c;
    --white: #ffffff;
    --card-bg: #f8f9ff;
    --shadow: 0 20px 60px rgba(13,27,62,0.18);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--navy);
    min-height: 100vh;
    padding: 40px 20px;
    background-image: 
      radial-gradient(ellipse at 20% 20%, rgba(245,166,35,0.12) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 80%, rgba(6,214,160,0.08) 0%, transparent 50%);
  }

  /* ---- Header ---- */
  .header {
    text-align: center;
    margin-bottom: 50px;
    animation: fadeDown 0.6s ease both;
  }
  .header-badge {
    display: inline-block;
    background: var(--gold);
    color: var(--navy);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 13px;
    letter-spacing: 3px;
    padding: 6px 18px;
    border-radius: 30px;
    margin-bottom: 14px;
  }
  .header h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(52px, 8vw, 90px);
    color: var(--white);
    line-height: 0.9;
    letter-spacing: 2px;
  }
  .header h1 span { color: var(--gold); }
  .header p {
    color: rgba(255,255,255,0.55);
    font-size: 15px;
    margin-top: 14px;
    letter-spacing: 0.5px;
  }
  .prize-pill {
    display: inline-block;
    background: linear-gradient(135deg, var(--gold), var(--gold-light));
    color: var(--navy);
    font-weight: 700;
    font-size: 14px;
    padding: 8px 22px;
    border-radius: 30px;
    margin-top: 16px;
    box-shadow: 0 4px 20px rgba(245,166,35,0.4);
    animation: pulse 2s ease infinite;
  }

  /* ---- Agent Tabs ---- */
  .tabs {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-bottom: 40px;
    flex-wrap: wrap;
    animation: fadeUp 0.6s 0.2s ease both;
  }
  .tab {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 1px;
    padding: 10px 26px;
    border-radius: 30px;
    border: 2px solid rgba(255,255,255,0.15);
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.5);
    cursor: pointer;
    transition: all 0.25s ease;
    text-transform: uppercase;
  }
  .tab:hover { border-color: var(--gold); color: var(--gold); }
  .tab.active {
    background: var(--gold);
    border-color: var(--gold);
    color: var(--navy);
    box-shadow: 0 4px 20px rgba(245,166,35,0.35);
  }

  /* ---- Cards Container ---- */
  .cards-wrapper {
    display: flex;
    justify-content: center;
    animation: fadeUp 0.6s 0.3s ease both;
  }
  .card-panel { display: none; }
  .card-panel.active { display: block; }

  /* ---- Bingo Card ---- */
  .bingo-card {
    background: var(--card-bg);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: var(--shadow);
    width: 100%;
    max-width: 520px;
    transition: transform 0.3s ease;
  }
  .bingo-card:hover { transform: translateY(-4px); }

  .card-header {
    background: var(--navy);
    padding: 24px 28px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 3px solid var(--gold);
  }
  .card-header-left h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    color: var(--white);
    letter-spacing: 2px;
  }
  .card-header-left .agent-name {
    font-size: 13px;
    color: var(--gold);
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-top: 2px;
  }
  .week-badge {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 10px;
    padding: 8px 14px;
    text-align: center;
  }
  .week-badge .week-label { font-size: 10px; color: rgba(255,255,255,0.4); letter-spacing: 1px; text-transform: uppercase; }
  .week-badge .week-val { font-size: 13px; color: var(--white); font-weight: 600; margin-top: 2px; }

  /* ---- Grid ---- */
  .bingo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    padding: 0;
  }

  .bingo-cell {
    aspect-ratio: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 14px 10px;
    text-align: center;
    cursor: pointer;
    position: relative;
    border: 1px solid rgba(13,27,62,0.1);
    transition: all 0.2s ease;
    user-select: none;
    background: var(--white);
  }
  .bingo-cell:hover { background: #eef2ff; }

  .bingo-cell .cell-icon {
    font-size: 22px;
    margin-bottom: 6px;
    display: block;
  }
  .bingo-cell .cell-text {
    font-size: 11.5px;
    font-weight: 600;
    color: var(--navy);
    line-height: 1.35;
  }

  /* FREE cell */
  .bingo-cell.free {
    background: linear-gradient(135deg, #06d6a0, #0cb58a);
    cursor: default;
    pointer-events: none;
  }
  .bingo-cell.free .cell-text { color: white; font-size: 14px; font-weight: 700; }
  .bingo-cell.free .cell-icon { font-size: 28px; }

  /* Checked state */
  .bingo-cell.checked {
    background: linear-gradient(135deg, var(--navy), #1a2f6e) !important;
  }
  .bingo-cell.checked .cell-text { color: var(--gold); }
  .bingo-cell.checked .cell-icon { filter: grayscale(1) brightness(2); }
  .bingo-cell.checked::after {
    content: '✓';
    position: absolute;
    top: 6px;
    right: 8px;
    font-size: 14px;
    color: var(--gold);
    font-weight: 900;
  }

  /* WIN highlight */
  .bingo-cell.winner {
    background: linear-gradient(135deg, var(--gold), var(--gold-light)) !important;
    animation: winPop 0.4s ease;
  }
  .bingo-cell.winner .cell-text { color: var(--navy); }
  .bingo-cell.winner::after { color: var(--navy); }

  /* ---- Card Footer ---- */
  .card-footer {
    background: var(--navy);
    padding: 14px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .progress-wrap { flex: 1; margin-right: 16px; }
  .progress-label {
    font-size: 11px;
    color: rgba(255,255,255,0.45);
    margin-bottom: 5px;
    text-transform: uppercase;
    letter-spacing: 0.8px;
  }
  .progress-bar {
    height: 6px;
    background: rgba(255,255,255,0.1);
    border-radius: 10px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--gold), var(--gold-light));
    border-radius: 10px;
    transition: width 0.4s ease;
    width: 11.1%; /* 1/9 for FREE square */
  }
  .squares-count {
    font-size: 20px;
    font-family: 'Bebas Neue', sans-serif;
    color: var(--gold);
    letter-spacing: 1px;
    white-space: nowrap;
  }
  .reset-btn {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.4);
    font-size: 11px;
    padding: 6px 12px;
    border-radius: 8px;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    transition: all 0.2s;
    margin-left: 10px;
  }
  .reset-btn:hover { border-color: var(--red); color: var(--red); }

  /* ---- Win Banner ---- */
  .win-banner {
    display: none;
    background: linear-gradient(135deg, var(--gold), var(--gold-light));
    padding: 18px 24px;
    text-align: center;
  }
  .win-banner.show { display: block; animation: fadeDown 0.5s ease; }
  .win-banner h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    color: var(--navy);
    letter-spacing: 2px;
  }
  .win-banner p { font-size: 13px; color: var(--navy); opacity: 0.7; margin-top: 4px; font-weight: 600; }

  /* ---- Leaderboard ---- */
  .leaderboard {
    max-width: 520px;
    margin: 40px auto 0;
    animation: fadeUp 0.6s 0.4s ease both;
  }
  .leaderboard h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    color: var(--white);
    letter-spacing: 2px;
