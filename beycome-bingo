          <span class="cell-icon">🌟</span>
          <span class="cell-text">FREE</span>
        </div>
        <div class="bingo-cell" onclick="toggle(this,'marc')">
          <span class="cell-icon">📋</span>
          <span class="cell-text">Close an Enhanced Package</span>
        </div>
        <!-- Row 3 -->
        <div class="bingo-cell" onclick="toggle(this,'marc')">
          <span class="cell-icon">🔥</span>
          <span class="cell-text">Close 4 Sales in One Day</span>
        </div>
        <div class="bingo-cell" onclick="toggle(this,'marc')">
          <span class="cell-icon">🏠</span>
          <span class="cell-text">Get 10 Free Listings in 1 Day</span>
        </div>
        <div class="bingo-cell" onclick="toggle(this,'marc')">
          <span class="cell-icon">📝</span>
          <span class="cell-text">Sell Prepaid Title</span>
        </div>
      </div>
      <div class="card-footer">
        <div class="progress-wrap">
          <div class="progress-label">Progress</div>
          <div class="progress-bar"><div class="progress-fill" id="prog-marc"></div></div>
        </div>
        <div class="squares-count" id="count-marc">1 / 9</div>
        <button class="reset-btn" onclick="resetCard('marc')">Reset</button>
      </div>
    </div>
  </div>

</div>

<!-- Leaderboard -->
<div class="leaderboard">
  <h3>📊 <span>LEADERBOARD</span></h3>
  <div id="leaderboard-rows"></div>
</div>

<!-- Instructions -->
<div class="instructions">
  <h4>📌 How to Play</h4>
  <ul>
    <li>Each agent has a unique randomized card</li>
    <li>Click a square when you complete that achievement</li>
    <li>Get a full row, column, or diagonal to win</li>
    <li>First to BINGO wins the $100 prize</li>
    <li>Round resets every week — new cards, new winners</li>
  </ul>
</div>

<script>
  // Track state per agent
  const state = {
    rose:   [false, false, false, false, true, false, false, false, false],
    kevin:  [false, false, false, false, true, false, false, false, false],
    sharon: [false, false, false, false, true, false, false, false, false],
    marc:   [false, false, false, false, true, false, false, false, false],
  };

  const wins = { rose: 0, kevin: 0, sharon: 0, marc: 0 };

  // Win patterns for 3x3
  const WIN_PATTERNS = [
    [0,1,2],[3,4,5],[6,7,8], // rows
    [0,3,6],[1,4,7],[2,5,8], // cols
    [0,4,8],[2,4,6]          // diagonals
  ];

  function toggle(cell, agent) {
    const grid = document.getElementById('grid-' + agent);
    const cells = [...grid.querySelectorAll('.bingo-cell')];
    const idx = cells.indexOf(cell);
    if (idx === 4) return; // FREE
    state[agent][idx] = !state[agent][idx];
    cell.classList.toggle('checked', state[agent][idx]);
    updateCard(agent);
  }

  function updateCard(agent) {
    const grid = document.getElementById('grid-' + agent);
    const cells = [...grid.querySelectorAll('.bingo-cell')];
    const s = state[agent];

    // Remove winner class first
    cells.forEach(c => c.classList.remove('winner'));

    // Check win
    let won = false;
    for (const pattern of WIN_PATTERNS) {
      if (pattern.every(i => s[i])) {
        pattern.forEach(i => cells[i].classList.add('winner'));
        won = true;
      }
    }

    // Win banner
    const banner = document.getElementById('win-' + agent);
    if (won && !banner.classList.contains('show')) {
      banner.classList.add('show');
      wins[agent]++;
    } else if (!won) {
      banner.classList.remove('show');
    }

    // Progress
    const completed = s.filter(Boolean).length;
    const pct = (completed / 9) * 100;
    document.getElementById('prog-' + agent).style.width = pct + '%';
    document.getElementById('count-' + agent).textContent = completed + ' / 9';

    updateLeaderboard();
  }

  function resetCard(agent) {
    state[agent] = [false, false, false, false, true, false, false, false, false];
    const grid = document.getElementById('grid-' + agent);
    const cells = [...grid.querySelectorAll('.bingo-cell')];
    cells.forEach((c, i) => {
      c.classList.remove('checked', 'winner');
      if (i === 4) c.classList.remove('checked');
    });
    document.getElementById('win-' + agent).classList.remove('show');
    document.getElementById('prog-' + agent).style.width = '11.1%';
    document.getElementById('count-' + agent).textContent = '1 / 9';
    updateLeaderboard();
  }

  function switchAgent(agent) {
    document.querySelectorAll('.card-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.getElementById('panel-' + agent).classList.add('active');
    event.target.classList.add('active');
  }

  function updateLeaderboard() {
    const agents = ['rose','kevin','sharon','marc'];
    const names = { rose:'Rose', kevin:'Kevin', sharon:'Sharon', marc:'Marc' };
    const rankEmojis = ['🥇','🥈','🥉',''];
    const rankClasses = ['gold','silver','bronze',''];

    const sorted = agents.map(a => ({
      name: names[a],
      id: a,
      squares: state[a].filter(Boolean).length,
      wins: wins[a]
    })).sort((a,b) => b.squares - a.squares || b.wins - a.wins);

    const container = document.getElementById('leaderboard-rows');
    container.innerHTML = sorted.map((agent, i) => `
      <div class="lb-row">
        <div class="lb-rank ${rankClasses[i]}">${rankEmojis[i] || (i+1)}</div>
        <div class="lb-agent">${agent.name}</div>
        <div class="lb-squares">${agent.squares}/9 squares</div>
        <div class="lb-wins ${agent.wins === 0 ? 'zero' : ''}">${agent.wins > 0 ? `🏆 ${agent.wins} BINGO${agent.wins>1?'s':''}` : 'No wins yet'}</div>
      </div>
    `).join('');
  }

  // Init leaderboard
  updateLeaderboard();
</script>
</body>
</html>
